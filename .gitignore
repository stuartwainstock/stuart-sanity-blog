# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/reports/

# next.js
/.next/
/out/

# Copied from maplibre-gl on postinstall (npm install regenerates)
public/maplibre-gl-csp-worker.js

# production
/build

# misc
.DS_Store
*.pem

# Never commit local git copies or SSH material (accidental workspace clutter)
.gitdata/
.ssh/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
