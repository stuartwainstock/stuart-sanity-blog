{
  "name": "sanity-blog",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:turbo": "next dev --turbopack",
    "tokens:build": "style-dictionary build --config config.style-dictionary.json",
    "prebuild": "npm run tokens:build",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "studio": "cd sanity && sanity dev",
    "studio:deploy": "cd sanity && sanity deploy",
    "typegen": "cd sanity && npm run typegen",
    "typecheck": "cd sanity && npm run typecheck",
    "audit:a11y": "npm run build && node scripts/a11y-audit.mjs",
    "audit:a11y:run": "node scripts/a11y-audit.mjs",
    "migrate:featured": "node scripts/migrate-featured-to-boolean.mjs",
    "postinstall": "node scripts/copy-maplibre-worker.mjs",
    "storybook": "storybook dev -p 6006",
    "prebuild-storybook": "npm run tokens:build",
    "build-storybook": "storybook build",
    "test:storybook": "vitest run --project storybook",
    "chromatic": "node ./scripts/chromatic.mjs",
    "tripit:transform": "node scripts/tripit-export-to-list-air.mjs"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "@mapbox/polyline": "^1.2.1",
    "@portabletext/react": "^4.0.3",
    "@sanity/client": "7.21.0",
    "@sanity/image-url": "^1.2.0",
    "@sanity/ui": "^3.1.8",
    "@sanity/vision": "5.21.0",
    "@supabase/supabase-js": "2.104.0",
    "jose": "^6.1.0",
    "maplibre-gl": "5.23.0",
    "next": "16.2.4",
    "next-sanity": "12.3.0",
    "oauth-1.0a": "^2.2.6",
    "open-graph-scraper": "^6.11.0",
    "ourairports-data-js": "^1.0.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-map-gl": "8.1.1",
    "sanity": "^5.20.0",
    "sanity-plugin-asset-source-unsplash": "^7.0.5",
    "sanity-plugin-ga-dashboard": "^1.0.6",
    "styled-components": "6.4.1"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "5.1.2",
    "@eslint/eslintrc": "^3.3.5",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-onboarding": "^10.3.5",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/nextjs-vite": "^10.3.5",
    "@types/mapbox__polyline": "^1.0.5",
    "@types/node": "^20",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19",
    "@vitest/browser": "4.1.4",
    "@vitest/browser-playwright": "4.1.4",
    "@vitest/coverage-v8": "4.1.4",
    "axe-core": "4.11.3",
    "chromatic": "16.3.0",
    "dotenv": "17.4.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.4",
    "eslint-plugin-storybook": "^10.3.5",
    "lighthouse": "^13.1.0",
    "playwright": "^1.59.1",
    "puppeteer-core": "24.42.0",
    "storybook": "^10.3.5",
    "style-dictionary": "^4.3.3",
    "typescript": "^5",
    "vite": "8.0.9",
    "vitest": "4.1.4"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
