{
  "color": {
    "$description": "Site color tokens (source for Style Dictionary → CSS variables)",
    "background": {
      "$type": "color",
      "$value": "#e8e8e8",
      "$description": "Default page background; matches body"
    },
    "link": {
      "$type": "color",
      "$value": "#0000FF",
      "$description": "Default anchor color (classic browser blue; base a / prose / link-custom)"
    },
    "link-hover": {
      "$type": "color",
      "$value": "#0000CC",
      "$description": "Link hover (darker blue; see globals a:hover)"
    },
    "custom": {
      "$type": "color",
      "50": { "$value": "#f9f9f9" },
      "100": { "$value": "#f0f0f0" },
      "200": { "$value": "#e8e8e8" },
      "300": { "$value": "#d1d1d1" },
      "400": { "$value": "#b8b8b8" },
      "500": { "$value": "#9f9f9f" },
      "600": { "$value": "#868686" },
      "700": { "$value": "#6d6d6d" },
      "800": { "$value": "#545454" },
      "900": { "$value": "#3b3b3b" }
    },
    "page-bg": {
      "$type": "color",
      "$value": "#e8e8e8",
      "$description": "Tailwind semantic page-bg"
    },
    "section-bg": {
      "$type": "color",
      "$value": "#f5f5f5",
      "$description": "Tailwind semantic section-bg"
    },
    "card-bg": {
      "$type": "color",
      "$value": "#ffffff",
      "$description": "Tailwind semantic card-bg"
    },
    "heading": {
      "$type": "color",
      "$value": "#4F4F4F",
      "$description": "h1–h6 default in globals"
    },
    "documented": {
      "$description": "Additional hex values referenced in globals / prose (migrate to usage over time)",
      "body": { "$type": "color", "$value": "#000000" },
      "prose-body": { "$type": "color", "$value": "#374151" },
      "prose-heading": { "$type": "color", "$value": "#111827" },
      "selection-bg": { "$type": "color", "$value": "#1f2937" },
      "selection-fg": { "$type": "color", "$value": "#f9fafb" }
    }
  }
}
