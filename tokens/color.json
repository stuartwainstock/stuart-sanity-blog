{
  "color": {
    "$description": "Site color tokens (source for Style Dictionary → CSS variables)",
    "background": {
      "$type": "color",
      "$value": "#e8e8e8",
      "$description": "Default page background; matches body"
    },
    "link": {
      "$type": "color",
      "$value": "#0000FF",
      "$description": "Default anchor color (classic browser blue; base a / prose / link-custom)"
    },
    "link-hover": {
      "$type": "color",
      "$value": "#0000CC",
      "$description": "Link hover (darker blue; see globals a:hover)"
    },
    "custom": {
      "$type": "color",
      "50": { "$value": "#f9f9f9" },
      "100": { "$value": "#f0f0f0" },
      "200": { "$value": "#e8e8e8" },
      "300": { "$value": "#d1d1d1" },
      "400": { "$value": "#b8b8b8" },
      "500": { "$value": "#9f9f9f" },
      "600": { "$value": "#868686" },
      "700": { "$value": "#6d6d6d" },
      "800": { "$value": "#545454" },
      "900": { "$value": "#3b3b3b" }
    },
    "page-bg": {
      "$type": "color",
      "$value": "#e8e8e8",
      "$description": "Semantic page background (e.g. `.bg-page`)"
    },
    "section-bg": {
      "$type": "color",
      "$value": "#f5f5f5",
      "$description": "Semantic section background (e.g. `.bg-section`)"
    },
    "card-bg": {
      "$type": "color",
      "$value": "#ffffff",
      "$description": "Semantic card/surface background (e.g. `.bg-card`)"
    },
    "heading": {
      "$type": "color",
      "$value": "#4F4F4F",
      "$description": "h1–h6 default in globals"
    },
    "documented": {
      "$description": "Additional hex values referenced in globals / prose (migrate to usage over time)",
      "body": { "$type": "color", "$value": "#000000" },
      "prose-body": { "$type": "color", "$value": "#374151" },
      "prose-heading": { "$type": "color", "$value": "#111827" },
      "selection-bg": { "$type": "color", "$value": "#ff9e9e" },
      "selection-fg": { "$type": "color", "$value": "#111827" }
    },
    "button": {
      "$description": "Semantic button surfaces (atoms/Button tone × variant)",
      "on-primary": {
        "$type": "color",
        "$value": "{color.card-bg}",
        "$description": "Label text on filled primary buttons (neutral and brand)"
      },
      "focus-inner": {
        "$type": "color",
        "$value": "{color.card-bg}",
        "$description": "Inner ring on focus-visible box-shadow"
      },
      "neutral": {
        "primary": {
          "bg": { "$type": "color", "$value": "{color.documented.prose-heading}" },
          "bg-hover": { "$type": "color", "$value": "#1f2937" },
          "focus-ring": { "$type": "color", "$value": "#9ca3af" }
        },
        "secondary": {
          "border": { "$type": "color", "$value": "#d1d5db" },
          "bg": { "$type": "color", "$value": "{color.card-bg}" },
          "bg-hover": { "$type": "color", "$value": "#f9fafb" },
          "text": { "$type": "color", "$value": "{color.documented.prose-body}" },
          "focus-ring": { "$type": "color", "$value": "#d1d5db" }
        },
        "ghost": {
          "text": { "$type": "color", "$value": "{color.documented.prose-heading}" },
          "bg-hover": { "$type": "color", "$value": "#f3f4f6" },
          "focus-ring": { "$type": "color", "$value": "#d1d5db" }
        }
      },
      "brand": {
        "primary": {
          "bg": { "$type": "color", "$value": "#c2410c" },
          "bg-hover": { "$type": "color", "$value": "#9a3412" },
          "focus-ring": { "$type": "color", "$value": "#f97316" }
        },
        "secondary": {
          "border": { "$type": "color", "$value": "#fdba74" },
          "bg": { "$type": "color", "$value": "{color.card-bg}" },
          "bg-hover": { "$type": "color", "$value": "#fff7ed" },
          "text": { "$type": "color", "$value": "#7c2d12" },
          "focus-ring": { "$type": "color", "$value": "#f97316" }
        },
        "ghost": {
          "text": { "$type": "color", "$value": "#7c2d12" },
          "bg-hover": { "$type": "color", "$value": "#fff7ed" },
          "focus-ring": { "$type": "color", "$value": "#f97316" }
        }
      }
    }
  }
}
