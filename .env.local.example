# Sanity Configuration
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production

# Optional: Sanity API Token for preview mode or mutations
# SANITY_API_TOKEN=your-api-token

# Quick-Add Link API
# Generate a write token in Sanity Manage -> API -> Tokens
# SANITY_API_WRITE_TOKEN=your-sanity-write-token
# (also used by npm run migrate:featured — run with DRY_RUN=1 first; see scripts/migrate-featured-to-boolean.mjs)
# QUICK_ADD_API_KEY=your-bookmarklet-secret

# Google Analytics (GA4) — site measurement (client)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# GA4 Data API — Sanity Studio “Google Analytics” tool (sanity-plugin-ga-dashboard)
# Server-only. Numeric Property ID from GA Admin → Property settings (not G-XXXXXXXX).
# Create a GCP service account, enable “Google Analytics Data API”, download JSON key.
# In GA: Admin → Property access management → add the service account email as Viewer.
# GA_PROPERTY_ID=123456789
# GA_SERVICE_ACCOUNT_EMAIL=your-sa@your-project.iam.gserviceaccount.com
# GA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# If you still see jose "pkcs8" errors on Vercel: paste the key as one line with \n between PEM lines,
# or use real line breaks in Vercel’s multiline env UI. The API route also converts literal \n to newlines.
# Hosted Studio (*.sanity.studio): `sanity.config` defaults to https://www.stuartwainstock.com/api/analytics when
# not building on Vercel (see PRODUCTION_SITE_ORIGIN). Override if your canonical host differs:
# NEXT_PUBLIC_SANITY_GA_API_URL=https://www.your-domain.com/api/analytics
# Vercel: allow your *.sanity.studio origin to read /api/analytics (comma-separated).
# SANITY_ANALYTICS_CORS_ORIGINS=https://stuartwainstock.sanity.studio
# Optional: hide the Studio tool without removing the plugin (e.g. preview deploys)
# SANITY_DISABLE_GA_DASHBOARD=1

# On-demand revalidation (Sanity webhook → refresh Next.js cache without deploy)
# Use a long random string. Webhook URL: https://YOUR_DOMAIN/api/revalidate?secret=THIS_VALUE
# SANITY_REVALIDATE_SECRET=

# eBird API (server-only; do not use NEXT_PUBLIC_)
# Request a key: https://ebird.org/api/keygen — used for /pileated-watch (map + table)
# EBIRD_API_KEY=

# Supabase (server-only secret — never expose to the client)
# Dashboard: Project Settings → API → Project URL + Secret key (service role)
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=

# Strava API (server-only) — https://www.strava.com/settings/api
# Authorization callback domain must match your site; path: /api/strava/callback
# Production: ADMIN_PASSWORD (+ optional ADMIN_SESSION_SECRET) gates OAuth so only you can bind Strava.
# Sign in at /admin/login before Connect Strava. Local dev only: ALLOW_INSECURE_STRAVA_CONNECT=1 skips the gate.
# ADMIN_PASSWORD=
# ADMIN_SESSION_SECRET=
# ALLOW_INSECURE_STRAVA_CONNECT=
# STRAVA_CLIENT_ID=
# STRAVA_CLIENT_SECRET=
# STRAVA_REDIRECT_URI=http://localhost:3000/api/strava/callback
# Optional: require Bearer token on POST /api/strava/sync (cron). Leave unset for local-only sync button.
# STRAVA_SYNC_SECRET=
# Optional: disable reverse geocoding (OpenStreetMap Nominatim) on /runs when only lat/lng exist.
# STRAVA_REVERSE_GEOCODE=0
# Optional: contact URL for Nominatim User-Agent (recommended in production).
# NOMINATIM_CONTACT_URL=https://your-site.example/about

# TripIt API (server-only) — /flights map. OAuth keys from TripIt developer portal.
# TRIPIT_CONSUMER_KEY=
# TRIPIT_CONSUMER_SECRET=
# TRIPIT_OAUTH_TOKEN=
# TRIPIT_OAUTH_TOKEN_SECRET=
# Optional: use slim list-air JSON instead of the live TripIt API (same shape as …/format/json).
# Generate from TripIt’s account export: npm run tripit:transform -- "/path/to/TripIt Data - You.json"
# If src/data/tripit/list-air-historical.json exists (e.g. committed slim data: dates + IATA only), it is
# used automatically; override or set another path with:
# TRIPIT_FLIGHTS_JSON=src/data/tripit/list-air-historical.json
