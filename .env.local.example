# Sanity Configuration
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production

# Optional: Sanity API Token for preview mode or mutations
# SANITY_API_TOKEN=your-api-token

# Quick-Add Link API
# Generate a write token in Sanity Manage -> API -> Tokens
# SANITY_API_WRITE_TOKEN=your-sanity-write-token
# (also used by npm run migrate:featured — run with DRY_RUN=1 first; see scripts/migrate-featured-to-boolean.mjs)
# QUICK_ADD_API_KEY=your-bookmarklet-secret

# Google Analytics (GA4) — site measurement (client)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Case studies (password-protected PDFs) — signs the per-study unlock cookie.
# Required to enable unlocking. Use a long random string (e.g. `openssl rand -hex 32`).
# Set in Vercel for production. Password hashes + PDF bytes live in private Supabase
# (`case_study_access` + `case-study-pdfs` bucket) — not in the public Sanity dataset/CDN.
# CASE_STUDY_SESSION_SECRET=
#
# Studio admin APIs (set password / upload PDF). Embedded /studio: sign in at /admin/login.
# Hosted *.sanity.studio also needs:
# - Vercel: CASE_STUDY_ADMIN_SECRET (+ optional CASE_STUDY_ADMIN_CORS_ORIGINS)
# - Sanity Manage Studio env:
#   SANITY_STUDIO_CASE_STUDY_API_BASE=https://www.your-domain.com
#   SANITY_STUDIO_CASE_STUDY_ADMIN_SECRET=SAME_AS_CASE_STUDY_ADMIN_SECRET
# CASE_STUDY_ADMIN_SECRET=
# CASE_STUDY_ADMIN_CORS_ORIGINS=https://YOUR_PROJECT.sanity.studio
#
# One-time migration of existing public CDN PDFs:
#   Apply scripts/supabase-case-study-access.sql, then:
#   node --env-file=.env.local scripts/migrate-case-study-pdfs-to-supabase.mjs
#   (DRY_RUN=1 first). Delete burned CDN assets is included; rotate weak passwords.

# On-demand revalidation (Sanity webhook → refresh Next.js cache without deploy)
# Use a long random string. Webhook URL: https://YOUR_DOMAIN/api/revalidate?secret=THIS_VALUE
# SANITY_REVALIDATE_SECRET=

# eBird API (server-only; do not use NEXT_PUBLIC_)
# Request a key: https://ebird.org/api/keygen — used for /pileated-watch (map + table)
# EBIRD_API_KEY=

# Unsplash API — optional; used only by local `npm run birding:suggest-unsplash` to write
# *suggestion* fields on `birdSighting` docs (Studio still approves Card image + alt text).
# Create an app at https://unsplash.com/oauth/applications — Access Key (public).
# UNSPLASH_ACCESS_KEY=

# Xeno-canto API key — required for audio suggestions on birdSighting docs.
# Register at https://xeno-canto.org and get a key from your Account page.
# Server-only (never expose to the client or Studio). Set in Vercel for production.
# XENO_CANTO_API_KEY=
# Studio UX: click-to-suggest from within the embedded Studio uses the same key,
# but requires admin login at /admin/login first (sets httpOnly session cookie).
#
# Hosted Studio (`*.sanity.studio`) cannot call relative `/api/*` routes. Configure:
# - In the Studio build (Sanity Manage → API → Environment variables):
#   SANITY_STUDIO_BIRDING_SUGGEST_API_URL=https://www.your-domain.com/api/birding/suggest-unsplash
#   SANITY_STUDIO_BIRDING_SUGGEST_SECRET=YOUR_RANDOM_SECRET
# - In Vercel (server env):
#   BIRDING_SUGGEST_PROXY_SECRET=YOUR_RANDOM_SECRET
#   SANITY_BIRDING_CORS_ORIGINS=https://YOUR_PROJECT.sanity.studio
# Regenerate Unsplash suggestion (next search page) for sightings already in `pending_review`:
#   npm run birding:regenerate-unsplash
# (same env file pattern: node --env-file=.env.local …)

# Supabase (server-only secret — never expose to the client)
# Dashboard: Project Settings → API → Project URL + Secret key (service role)
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=

# Strava API (server-only) — https://www.strava.com/settings/api
# Authorization callback domain must match your site; path: /api/strava/callback
# Production: ADMIN_PASSWORD (+ optional ADMIN_SESSION_SECRET) gates OAuth so only you can bind Strava.
# Sign in at /admin/login before Connect Strava. Local dev only: ALLOW_INSECURE_STRAVA_CONNECT=1 skips the gate.
# ADMIN_PASSWORD=
# ADMIN_SESSION_SECRET=
# ALLOW_INSECURE_STRAVA_CONNECT=
# STRAVA_CLIENT_ID=
# STRAVA_CLIENT_SECRET=
# STRAVA_REDIRECT_URI=http://localhost:3000/api/strava/callback
# Optional: require Bearer token on POST /api/strava/sync (cron). Leave unset for local-only sync button.
# STRAVA_SYNC_SECRET=
# Optional: disable reverse geocoding (OpenStreetMap Nominatim) on /runs when only lat/lng exist.
# STRAVA_REVERSE_GEOCODE=0
# Optional: contact URL for Nominatim User-Agent (recommended in production).
# NOMINATIM_CONTACT_URL=https://your-site.example/about

# TripIt API (server-only) — /flights map. OAuth keys from TripIt developer portal.
# TRIPIT_CONSUMER_KEY=
# TRIPIT_CONSUMER_SECRET=
# TRIPIT_OAUTH_TOKEN=
# TRIPIT_OAUTH_TOKEN_SECRET=
# Optional: use slim list-air JSON instead of the live TripIt API (same shape as …/format/json).
# Generate from TripIt’s account export: npm run tripit:transform -- "/path/to/TripIt Data - You.json"
# If src/data/tripit/list-air-historical.json exists (e.g. committed slim data: dates + IATA only), it is
# used automatically; override or set another path with:
# TRIPIT_FLIGHTS_JSON=src/data/tripit/list-air-historical.json
