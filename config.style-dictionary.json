{
  "source": ["tokens/**/*.json"],
  "platforms": {
    "css": {
      "transformGroup": "css",
      "buildPath": "src/styles/generated/",
      "files": [
        {
          "destination": "tokens.css",
          "format": "css/variables",
          "options": {
            "showFileHeader": true,
            "selector": [":root"]
          }
        }
      ]
    }
  }
}
